doctype html
html
  head
    title Add movie
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css")
  body
    .container.mt-5
      h1.mb-4 New movie

      form(action='/addmovie', method='POST')
        .mb-3
          label.form-label(for="title") Title
          input.form-control(type="text", name="title", id="title", placeholder="Enter movie title")

        .mb-3
          label.form-label(for="director") Director
          input.form-control(type="text", name="director", id="director", placeholder="Enter director")

        .mb-3
          label.form-label(for="year") Year
          input.form-control(type="number", name="year", id="year", placeholder="Enter year")

        button.btn.btn-primary(type="submit") Add